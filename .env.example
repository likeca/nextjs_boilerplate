# App Configuration
NEXT_PUBLIC_APP_NAME="SaaS App"
NEXT_PUBLIC_APP_DESCRIPTION="A production-ready SaaS boilerplate"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_LOGO="/logo.png"

# Database (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# Authentication (better-auth)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-at-least-32-characters-long"
BETTER_AUTH_URL="http://localhost:3000"

# Feature Flags
# Set to "false" to disable Two-Factor Authentication (TOTP) across the entire app
NEXT_PUBLIC_ENABLE_TWO_FACTOR="true"
# Set to "false" to disable email verification on signup (users can sign in immediately)
NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION="true"

# Stripe Payments
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Email / SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="noreply@yourapp.com"
SUPPORT_EMAIL="support@yourapp.com"

# OAuth Social Login (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Analytics (optional - all are optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# Company Info (optional)
NEXT_PUBLIC_COMPANY_NAME=""
NEXT_PUBLIC_COMPANY_ADDRESS=""
NEXT_PUBLIC_TWITTER_URL=""
NEXT_PUBLIC_GITHUB_URL=""
NEXT_PUBLIC_LINKEDIN_URL=""

# Feature Flags
NEXT_PUBLIC_ENABLE_TWO_FACTOR="false"
NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION="true"